# ==========================================
# Bill Matrix — Environment Variables Reference
# Copy this file to .env.local and fill in real values as each phase is implemented.
# Do NOT commit .env.local or any file with real secrets.
# ==========================================

# --- App ---
NEXT_PUBLIC_APP_URL=                     # e.g. http://localhost:3000 in dev

# --- Database (Neon Postgres) — added in Phase 2 ---
DATABASE_URL=                            # Neon POOLED connection string — used by the running app (ends in ?sslmode=require)
DATABASE_URL_UNPOOLED=                   # Neon DIRECT/unpooled connection string — used only by Drizzle Kit for migrations

# --- Auth (Neon Auth / Better Auth) — added in Phase 3 ---
BETTER_AUTH_SECRET=                      # random secret used to sign sessions
BETTER_AUTH_URL=                         # base URL of the app, e.g. http://localhost:3000
# Note: confirm exact variable names required by Neon Auth's setup wizard when Phase 3 is implemented —
# these may differ slightly from the generic Better Auth names above.

# --- File Storage (iDrive e2, S3-compatible) — added in Phase 11 ---
IDRIVE_E2_ACCESS_KEY=
IDRIVE_E2_SECRET_KEY=
IDRIVE_E2_ENDPOINT=                      # iDrive e2 S3-compatible endpoint URL
IDRIVE_E2_BUCKET_NAME=
IDRIVE_E2_REGION=

# --- Transactional Email (Resend) — added in Phase 16 ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=                       # verified sender address/domain

# --- Rate Limiting / Cache (Upstash Redis) — added in Phase 17 ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Monitoring & Logging (Sentry) — added in Phase 18 ---
SENTRY_DSN=
SENTRY_AUTH_TOKEN=                       # used only for uploading source maps at build time
